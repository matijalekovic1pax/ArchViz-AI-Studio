# Appwrite Cloud feedback backend setup.
# Copy to .env.appwrite locally or export these variables before running:
# npm run setup:appwrite-feedback

APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=6a28198a0007906d225d
APPWRITE_API_KEY=replace-with-server-api-key

# Resource IDs used by the Cloudflare Worker.
APPWRITE_DATABASE_ID=archviz_reports
APPWRITE_REPORTS_COLLECTION_ID=feedback_reports
APPWRITE_ACTIVITY_COLLECTION_ID=feedback_activity
APPWRITE_ADMINS_COLLECTION_ID=feedback_admins
APPWRITE_SNAPSHOTS_BUCKET_ID=feedback_snapshots

# Admin account seeded into feedback_admins.
APPWRITE_FEEDBACK_ADMIN_EMAIL=matija.lekovic@1pax.com
