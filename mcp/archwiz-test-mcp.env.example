# Optional settings for the ArchWiz testing MCP server.
# The server also works with defaults when the app is running on Vite's default port.

# App URL opened by archwiz_launch_app.
ARCHWIZ_TEST_APP_URL=http://127.0.0.1:5173/

# Chrome DevTools remote debugging port used by the MCP-managed browser.
ARCHWIZ_TEST_REMOTE_DEBUGGING_PORT=9322

# Optional: point to a Chrome/Chromium/Edge executable if auto-detection fails.
# ARCHWIZ_TEST_BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional: where screenshots and saved renders are written by default.
# ARCHWIZ_TEST_OUTPUT_DIR=/tmp/archwiz-test-mcp

# Optional: persistent browser profile used for test automation.
# ARCHWIZ_TEST_BROWSER_PROFILE_DIR=/tmp/archwiz-test-mcp-profile-9322

# Optional: print browser stderr to MCP stderr for debugging.
# ARCHWIZ_TEST_DEBUG=1
