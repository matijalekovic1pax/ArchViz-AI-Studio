# Copy this file to .env.feedback-mcp and fill in values.
# The MCP server loads .env.feedback-mcp automatically.

# Backend selection: auto | supabase | gateway
FEEDBACK_MCP_BACKEND=auto

# Actor identity shown in feedback activity timeline
FEEDBACK_MCP_ACTOR_EMAIL=matija.lekovic@1pax.com
FEEDBACK_MCP_ACTOR_NAME=Feedback MCP

# ──────────────────────────────────────────────────────────────────────────────
# Option A (recommended): Supabase direct access
# Requires service-role credentials.
# ──────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ──────────────────────────────────────────────────────────────────────────────
# Option B: Feedback API gateway (admin token required)
# ──────────────────────────────────────────────────────────────────────────────
# FEEDBACK_API_BASE_URL=https://archviz-api-gateway-prod.matija-lekovic.workers.dev
# FEEDBACK_API_TOKEN=your_admin_gateway_jwt
