# ─── Cloudflare Worker API Gateway ───────────────────────────────────────────
VITE_API_GATEWAY_URL=http://localhost:8787
# Production: VITE_API_GATEWAY_URL=https://avas-api-gateway.your-subdomain.workers.dev
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_ALLOWED_DOMAIN=your-company-domain.com

# Feedback reports are stored server-side through the Cloudflare Worker.
# Use .env.appwrite for local setup scripts and Wrangler secrets for production;
# do not expose APPWRITE_API_KEY as a VITE_* browser variable.

# ─── Stripe (Publishable key only — secret keys go in Cloudflare Worker secrets)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create these in your Stripe dashboard)
VITE_STRIPE_STARTER_PRICE_ID=price_...
VITE_STRIPE_PROFESSIONAL_PRICE_ID=price_...
VITE_STRIPE_STUDIO_PRICE_ID=price_...
VITE_STRIPE_CREDITS_500_PRICE_ID=price_...
VITE_STRIPE_CREDITS_2000_PRICE_ID=price_...

# ─── PDF Converter (Vercel serverless) ───────────────────────────────────────
VITE_PDF_CONVERTER_API_URL=https://your-pdf-api.vercel.app

# ─── Optional ─────────────────────────────────────────────────────────────────
# VITE_VEO_PROXY_URL=https://your-veo-proxy.workers.dev
# VITE_ILOVEPDF_PUBLIC_KEY=your_key_here
